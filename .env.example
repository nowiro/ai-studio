# AI Studio – local environment template
#
# Copy to .env.local (gitignored). NEVER commit real values.
# Production secrets live in the platform's secret manager, not here.

# ── Backend / AI ──────────────────────────────────────────────
# Server-only: the Genkit / Cloud Function reads these. Never ship to client.
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Telemetry ────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# ── Public (build-time) ──────────────────────────────────────
# Anything prefixed with PUBLIC_ may be inlined into the client bundle.
PUBLIC_APP_BASE_URL=http://localhost:4200
PUBLIC_API_BASE_URL=http://localhost:3000
