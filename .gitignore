report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Coverage & test artifacts
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/
blob-report/

# Environment & secrets
.env
.env.local
.env.*.local
*.pem
.secrets/

# AI runtime & cache (NOT configuration — configs are committed)
.ai/.cache/
.ai/.runtime/
.claude/.cache/
.claude/projects/
.claude/local/
.claude/settings.local.json

# OS generated
ehthumbs.db
desktop.ini

# Misc
.firebase/
.netlify/
.vercel/
storybook-static/

.nx/polygraph
.claude/worktrees
.angular

vite.config.*.timestamp*
vitest.config.*.timestamp*
.nx/self-healing

# Python cache from tools/scripts/*.py (favicon generator etc.)
__pycache__/
*.pyc

# llm-call.mjs runtime — per-call cache + audit log (local; never committed).
# Fixtures (.fixtures/llm-calls/) ARE committed — they back CI mock mode.
tools/scripts/.cache/
__screenshots__/

# AI task artifacts — real plans / specs / run reports stay LOCAL only (per
# project decision): created locally, never committed. Scaffolding IS kept —
# .gitkeep placeholders + _template files (docs/ai-workflow/plans/_template.md
# is a trinity baseline: must stay committed & byte-identical across repos).
# NOTE: plans/specs already committed in this repo stay tracked (gitignore does
# not untrack) — only NEW artifacts become local-only here.
docs/ai-workflow/plans/*
docs/ai-workflow/runs/*
docs/analytical/specs/*
!docs/ai-workflow/plans/.gitkeep
!docs/ai-workflow/plans/_template.md
!docs/ai-workflow/runs/.gitkeep
!docs/analytical/specs/.gitkeep
!docs/analytical/specs/_template/
