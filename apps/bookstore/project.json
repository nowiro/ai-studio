{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "bookstore",
  "projectType": "application",
  "prefix": "ais",
  "sourceRoot": "apps/bookstore/src",
  "tags": ["scope:bookstore", "type:app"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/bookstore",
        "index": "apps/bookstore/src/index.html",
        "browser": "apps/bookstore/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/bookstore/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": ["apps/bookstore/src/favicon.ico"],
        "styles": ["styles/tailwind.scss", "apps/bookstore/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "budgets": [
            { "type": "initial", "maximumWarning": "750kB", "maximumError": "1.5mB" },
            { "type": "anyComponentStyle", "maximumWarning": "6kB", "maximumError": "10kb" }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "build-element": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/bookstore-element",
        "browser": "apps/bookstore/src/element.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/bookstore/tsconfig.app.json",
        "assets": [],
        "styles": ["styles/tailwind.scss", "apps/bookstore/src/styles.scss"],
        "outputHashing": "none",
        "budgets": [{ "type": "initial", "maximumWarning": "1.8mB", "maximumError": "3mB" }]
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "port": 4208
      },
      "configurations": {
        "production": { "buildTarget": "bookstore:build:production" },
        "development": { "buildTarget": "bookstore:build:development" }
      },
      "defaultConfiguration": "development"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/bookstore/tsconfig.app.json --noEmit"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
