{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "personal-data-wizard",
  "projectType": "application",
  "sourceRoot": "apps/personal-data-wizard/src",
  "tags": ["scope:wizard", "type:app"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/personal-data-wizard",
        "index": "apps/personal-data-wizard/src/index.html",
        "browser": "apps/personal-data-wizard/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/personal-data-wizard/tsconfig.app.json",
        "assets": [],
        "styles": ["styles/tailwind.scss", "apps/personal-data-wizard/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "budgets": [{ "type": "initial", "maximumWarning": "1.5mB", "maximumError": "2.5mB" }],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "port": 4203
      },
      "configurations": {
        "production": { "buildTarget": "personal-data-wizard:build:production" },
        "development": { "buildTarget": "personal-data-wizard:build:development" }
      },
      "defaultConfiguration": "development"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/personal-data-wizard/tsconfig.app.json --noEmit"
      }
    }
  }
}
