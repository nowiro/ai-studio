{
  "name": "union-vault",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "ais",
  "sourceRoot": "apps/union-vault/src",
  "tags": ["scope:union-vault", "type:app"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/union-vault",
        "browser": "apps/union-vault/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/union-vault/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/union-vault/public"
          }
        ],
        "styles": ["styles/tailwind.scss", "apps/union-vault/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "650kb",
              "maximumError": "1.5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "10kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "build-element": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/union-vault-element",
        "browser": "apps/union-vault/src/element.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/union-vault/tsconfig.app.json",
        "assets": [],
        "styles": ["styles/tailwind.scss", "apps/union-vault/src/styles.scss"],
        "outputHashing": "none",
        "budgets": [{ "type": "initial", "maximumWarning": "1.8mB", "maximumError": "3mB" }]
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "port": 4201
      },
      "configurations": {
        "production": {
          "buildTarget": "union-vault:build:production"
        },
        "development": {
          "buildTarget": "union-vault:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "union-vault:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "runner": "vitest"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "union-vault:build",
        "port": 4201,
        "staticFilePath": "dist/apps/union-vault/browser",
        "spa": true
      }
    }
  }
}
