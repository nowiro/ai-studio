{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "charts",
  "$schema_comment": "Library-agnostic Angular chart wrappers backed by Apache ECharts. See docs/adr/0016-charts-abstraction-echarts.md for the abstraction contract.",
  "projectType": "library",
  "sourceRoot": "libs/charts/src",
  "tags": ["scope:shared", "type:ui"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/libs/charts"],
      "options": {
        "command": "vitest run",
        "cwd": "libs/charts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/charts/tsconfig.json --noEmit"
      }
    }
  }
}
