{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "dashboard-feature",
  "projectType": "library",
  "sourceRoot": "libs/dashboard-feature/src",
  "tags": ["scope:dashboard", "type:feature"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/libs/dashboard-feature"],
      "options": {
        "command": "vitest run",
        "cwd": "libs/dashboard-feature"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/dashboard-feature/tsconfig.json --noEmit"
      }
    }
  }
}
