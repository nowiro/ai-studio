{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "game-pong",
  "$schema_comment": "Framework-agnostic Phaser game library. Tags enforce module boundaries.",
  "projectType": "library",
  "sourceRoot": "libs/game-pong/src",
  "tags": ["scope:game", "type:feature", "type:util"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/libs/game-pong"],
      "options": {
        "command": "vitest run",
        "cwd": "libs/game-pong"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/game-pong/tsconfig.json --noEmit"
      }
    }
  }
}
