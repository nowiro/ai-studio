{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "game-tetris",
  "metadata": { "description": "Framework-agnostic Tetris logic + state lib. Tags enforce module boundaries." },
  "projectType": "library",
  "sourceRoot": "libs/game-tetris/src",
  "tags": ["scope:game-tetris", "type:util"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/libs/game-tetris"],
      "options": {
        "command": "vitest run",
        "cwd": "libs/game-tetris"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/game-tetris/tsconfig.json --noEmit"
      }
    }
  }
}
