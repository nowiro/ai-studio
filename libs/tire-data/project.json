{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "tire-data",
  "$schema_comment": "Domain models + signal services + pure filter/sort fns for tire-shop.",
  "projectType": "library",
  "sourceRoot": "libs/tire-data/src",
  "tags": ["scope:tire-shop", "type:data-access", "type:util"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/libs/tire-data"],
      "options": {
        "command": "vitest run",
        "cwd": "libs/tire-data"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/tire-data/tsconfig.json --noEmit"
      }
    }
  }
}
