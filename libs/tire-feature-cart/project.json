{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "tire-feature-cart",
  "metadata": { "description": "Cart drawer + cart page + 4-step checkout for tire-shop." },
  "projectType": "library",
  "sourceRoot": "libs/tire-feature-cart/src",
  "tags": ["scope:tire-shop", "type:feature"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/libs/tire-feature-cart"],
      "options": {
        "command": "vitest run",
        "cwd": "libs/tire-feature-cart"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/tire-feature-cart/tsconfig.json --noEmit"
      }
    }
  }
}
