{
  "name": "ai-studio",
  "version": "0.1.0",
  "private": true,
  "description": "AI Studio – Angular 21 Nx monorepo starter with Material + Tailwind v4 and a multi-agent AI workflow",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "prepare": "husky",
    "bootstrap": "node tools/scripts/bootstrap.mjs",
    "start": "nx serve pong-game --port 4200",
    "start:pong-game": "nx serve pong-game --port 4200",
    "start:personal-data-wizard": "nx serve personal-data-wizard --port 4201",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "test:watch": "nx run-many -t test --watch",
    "test:cov": "nx run-many -t test --coverage",
    "e2e": "nx run-many -t e2e",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint --fix",
    "format": "prettier --write \"**/*.{ts,html,scss,css,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,html,scss,css,json,md,yml,yaml}\"",
    "typecheck": "tsc -p tsconfig.base.json --noEmit && nx run-many -t typecheck",
    "graph": "nx graph",
    "affected": "nx affected",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "affected:build": "nx affected -t build",
    "affected:e2e": "nx affected -t e2e",
    "commit": "cz",
    "release": "nx release",
    "ai:context": "node tools/scripts/build-ai-context.mjs",
    "ai:validate": "node tools/scripts/validate-ai-config.mjs",
    "docs:scan": "node tools/scripts/scan-docs.mjs",
    "docs:api": "node tools/scripts/scan-public-api.mjs",
    "docs:audit": "node tools/scripts/doc-audit.mjs",
    "test:scenarios": "node tools/scripts/scenarios-from-specs.mjs",
    "trinity:check": "node tools/scripts/check-trinity.mjs",
    "docs:lint": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#dist\" \"#coverage\" \"#.nx\"",
    "docs:linkcheck": "lychee --config lychee.toml --no-progress \"./**/*.md\""
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.0.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "phaser": "^3.87.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.0.0",
    "@angular-eslint/eslint-plugin": "^21.0.0",
    "@angular-eslint/eslint-plugin-template": "^21.0.0",
    "@angular-eslint/schematics": "^21.0.0",
    "@angular-eslint/template-parser": "^21.0.0",
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/language-service": "^21.0.0",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.39.4",
    "@nx/angular": "^21.0.0",
    "@nx/devkit": "^21.0.0",
    "@nx/eslint": "^21.0.0",
    "@nx/eslint-plugin": "^21.0.0",
    "@nx/js": "^21.0.0",
    "@nx/playwright": "^21.0.0",
    "@nx/workspace": "^21.0.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@typescript-eslint/utils": "^8.59.3",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "angular-eslint": "^21.3.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-rxjs-x": "^1.0.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-tailwindcss": "4.0.0-beta.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jiti": "^2.4.0",
    "jsdom": "^25.0.0",
    "lint-staged": "^15.2.10",
    "markdownlint-cli2": "^0.14.0",
    "nx": "^21.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.4.0",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^2.1.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{ts,html}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md,yml,yaml,scss,css}": [
      "prettier --write"
    ]
  }
}
