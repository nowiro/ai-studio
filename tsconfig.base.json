{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "es2022",
    "lib": ["es2022", "dom", "dom.iterable"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "useDefineForClassFields": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": false,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": true,
    "alwaysStrict": true,
    "paths": {
      "@ai-studio/business-wizard-data": ["./libs/business-wizard-data/src/index.ts"],
      "@ai-studio/business-wizard-feature": ["./libs/business-wizard-feature/src/index.ts"],
      "@ai-studio/charts": ["./libs/charts/src/index.ts"],
      "@ai-studio/wizard-core": ["./libs/wizard-core/src/index.ts"],
      "@ai-studio/game-pong": ["./libs/game-pong/src/index.ts"],
      "@ai-studio/game-pong-ui": ["./libs/game-pong-ui/src/index.ts"],
      "@ai-studio/game-tetris": ["./libs/game-tetris/src/index.ts"],
      "@ai-studio/game-tetris-ui": ["./libs/game-tetris-ui/src/index.ts"],
      "@ai-studio/journal-data": ["./libs/journal-data/src/index.ts"],
      "@ai-studio/journal-feature-attendance": ["./libs/journal-feature-attendance/src/index.ts"],
      "@ai-studio/journal-feature-grades": ["./libs/journal-feature-grades/src/index.ts"],
      "@ai-studio/journal-feature-shell": ["./libs/journal-feature-shell/src/index.ts"],
      "@ai-studio/journal-feature-timetable": ["./libs/journal-feature-timetable/src/index.ts"],
      "@ai-studio/journal-ui": ["./libs/journal-ui/src/index.ts"],
      "@ai-studio/shared-app-shell": ["./libs/shared-app-shell/src/index.ts"],
      "@ai-studio/shop-core": ["./libs/shop-core/src/index.ts"],
      "@ai-studio/shop-ui": ["./libs/shop-ui/src/index.ts"],
      "@ai-studio/bookstore-data": ["./libs/bookstore-data/src/index.ts"],
      "@ai-studio/bookstore-feature-catalogue": ["./libs/bookstore-feature-catalogue/src/index.ts"],
      "@ai-studio/tools-shop-data": ["./libs/tools-shop-data/src/index.ts"],
      "@ai-studio/tools-shop-feature-catalogue": ["./libs/tools-shop-feature-catalogue/src/index.ts"],
      "@ai-studio/toy-shop-data": ["./libs/toy-shop-data/src/index.ts"],
      "@ai-studio/toy-shop-feature-catalogue": ["./libs/toy-shop-feature-catalogue/src/index.ts"],
      "@ai-studio/library-data": ["./libs/library-data/src/index.ts"],
      "@ai-studio/library-feature-account": ["./libs/library-feature-account/src/index.ts"],
      "@ai-studio/library-feature-catalogue": ["./libs/library-feature-catalogue/src/index.ts"],
      "@ai-studio/library-feature-librarian": ["./libs/library-feature-librarian/src/index.ts"],
      "@ai-studio/library-ui": ["./libs/library-ui/src/index.ts"],
      "@ai-studio/shared-language": ["./libs/shared-language/src/index.ts"],
      "@ai-studio/tire-data": ["./libs/tire-data/src/index.ts"],
      "@ai-studio/tire-feature-cart": ["./libs/tire-feature-cart/src/index.ts"],
      "@ai-studio/tire-feature-catalogue": ["./libs/tire-feature-catalogue/src/index.ts"],
